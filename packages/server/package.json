{
  "name": "@darkcode/server",
  "type": "module",
  "private": "true",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "postinstall": "bun run --cwd ../database db:generate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/openai": "^3.0.71",
    "@darkcode/database": "workspace:*",
    "@darkcode/shared": "workspace:*",
    "@hono/zod-validator": "^0.8.0",
    "@sentry/bun": "^10.57.0",
    "@sentry/hono": "^10.57.0",
    "ai": "^6.0.205",
    "dotenv": "^17.4.2",
    "hono": "^4.12.25",
    "zod": "^4.4.3"
  }
}
